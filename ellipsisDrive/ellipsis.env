ENVIRONMENT=production
ELLIPSIS_FOLDER=/home/ellipsis/
CLOUD=aws
COMPANY_NAME=<<<companyName>>>
DEPLOYMENT_NAME=<<<deploymentName>>>
ENABLE_PLANS=<<<enablePlans>>>
AVAILABILITY_ZONE=<<<masterZone>>>
AVAILABILITY_ZONE_ABBREVIATION=<<<masterZoneAbbreviation>>>
MASTER_ZONE=<<<masterZone>>>
MAIN_LOCATION=<<<masterZoneAbbreviation>>>
MASTER_API_URL=https://<<<apiUrl>>>
API_URL=https://<<<apiUrl>>>
POSTGRES_DB=ellipsis
POSTGRES_APP_USER=ellipsis_app
POSTGRES_HOST=owl-rw
POSTGRES_HOST_LOCAL=cache-db-rw
POSTGRES_HOST_PORT=5432
POSTGRES_DB_LOCAL=api_cache
POSTGRES_APP_USER_LOCAL=local_api
POSTGRES_HOST_PORT_LOCAL=5432
POSTGRES_DB_SHAPE=ellipsis
POSTGRES_APP_USER_SHAPE=ellipsis_app
POSTGRES_HOST_PORT_SHAPE=5432
EFS_PATH=/mnt/efs/
ETMPFS_PATH=/mnt/etmpfs/
RAM_DISK=/mnt/tmpfs/
PYTHON_SCRIPTS_PATH=/home/ellipsis/python/
KEYS_FOLDER=/mnt/shared/.keys
FRONTEND_URL=https://<<<frontendUrl>>>
USE_TILE_SERVICE_CACHE=false
TILE_SERVICE_CACHE_PATH=/mnt/tileServiceCache
POOL_SIZE=4
KUBERNETES=true
LIST_FEATURES_PATH=/mnt/listFeatures