apiVersion: eksctl.io/v1alpha5
kind: ClusterConfig

metadata:
  name: <<<clusterName>>>
  region: <<<masterZone>>>
  version: "<<<kubernetesVersion>>>"

vpc:
  subnets:
    private:
      <<<masterZone>>>b: { id: <<<subnetId1>>> }
      <<<masterZone>>>a: { id: <<<subnetId2>>> }

upgradePolicy: 
  supportType: STANDARD

iam:
  withOIDC: true

autoModeConfig:
  enabled: true

addons:
  # - name: vpc-cni
  # - name: coredns
  # - name: kube-proxy
  - name: aws-ebs-csi-driver
  - name: aws-efs-csi-driver
  # - name: eks-pod-identity-agent
  - name: external-dns
  # - name: metrics-server